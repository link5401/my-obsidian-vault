filters:
  and:
    - '!file.name.contains("Template")'
    - categories.contains(link("People"))
properties:
  file.name:
    displayName: Name
  note.org:
    displayName: Org
  note.tags:
    displayName: Tags
views:
  - type: table
    name: People
    order:
      - file.name
      - org
      - tags
